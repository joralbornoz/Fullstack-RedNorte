# ✅ RUTA CENTRAL DEL API GATEWAY (Rutas públicas como el Login/Auth)
# Machea con: Path=/api/v1/auth/** en tu application.yml e irá al puerto 8001
VITE_API_GATEWAY_URL=http://localhost:8080/api/v1

# ✅ RUTA DEL BFF CANALIZADA POR EL API GATEWAY (Para todo el negocio y pantallas)
# Cambiamos el puerto 8081 por el 8080. El Gateway leerá el fragmento '/bff' 
# y redirigirá la petición internamente al puerto 8081 de manera transparente.
VITE_API_BFF_URL=http://localhost:8080/api/v1/bff